# Database Configuration
# Default is set to mysql as per the technical requirement
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=widapos_db

# Application Configuration
PORT=3000
NODE_ENV=development

# AI Features (Optional)
# AI Studio automatically injects this at runtime if configured in the Secrets panel.
GEMINI_API_KEY=
